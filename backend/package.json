{
  "name": "quizup-backend",
  "version": "1.0.0",
  "description": "QuizUp Arena real-time backend — Node.js + Express + Socket.io + MongoDB + Redis",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:worker": "node src/pipelineWorkerEntry.js",
    "seed": "node src/scripts/seed.js",
    "migrate:s3": "node src/scripts/migrateImagesToS3.js",
    "migrate:s3:upload-only": "node src/scripts/migrateImagesToS3.js --upload-only",
    "migrate:s3:animal-celebrity": "node src/scripts/migrateImagesToS3.js --upload-only --folders=name-the-celebrity-seed,name-the-animal-seed"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/lib-storage": "^3.1033.0",
    "bullmq": "^5.34.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.2",
    "express-validator": "^7.2.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.2",
    "mongoose": "^8.4.0",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
